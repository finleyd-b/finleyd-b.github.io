/*-- scss:defaults --*/

// Sass Variables
// https://quarto.org/docs/output-formats/html-themes.html#sass-variables

/* Colors */
$body-bg: #FFFFFF;
$body-color: #FF83FA;
$link-color: #FFFFF0;

/* Fonts */
$font-family-sans-serif: "Source Sans Pro", -apple-system, "system-ui", "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif, "Apple Color Emoji", "Segoe UI Emoji", "Segoe UI Symbol";
$font-size-root: 17px;

// Navbar styling
$navbar-bg: #DA70D6; // Navbar background color
$navbar-fg: #FFFFF0; // Navbar foreground (text/link) color
$navbar-hl: #FF83FA; // Highlight color for hovered links only

.navbar a:hover {
  color: $navbar-hl;
}
.navbar a.active {
  color: #FFFFF0
}
